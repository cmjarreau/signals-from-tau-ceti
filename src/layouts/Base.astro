---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Signals from Tau Ceti',
  description = 'A record of transmissions. Marathon lore, worldbuilding, and fragments.',
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title === 'Signals from Tau Ceti' ? title : `${title} — Signals from Tau Ceti`}</title>
  </head>
  <body>
    <header>
      <div class="header-bar container">
        <span>CYBERACME 802.11 // NEURO.FILTER ACTIVE</span>
        <span>TAU CETI IV · 2794.{new Date().getFullYear()}</span>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container">
        <div class="footer-inner">
          <span>// END OF TRANSMISSION</span>
          <span>ALL SIGNALS LOGGED · {new Date().getFullYear()}</span>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  header {
    border-bottom: 1px solid var(--border);
  }

  .header-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 0.9rem;
    font-size: 0.65rem;
    color: var(--text-dim);
    letter-spacing: 0.08em;
  }

  main {
    padding-block: 4rem;
  }

  footer {
    border-top: 1px solid var(--border);
    padding-block: 1.25rem;
    font-size: 0.65rem;
    color: var(--text-dim);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    letter-spacing: 0.1em;
  }
</style>
