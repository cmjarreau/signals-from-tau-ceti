---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('entries');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Base title={entry.data.title} description={entry.data.description}>
  <article class="container">
    <header class="entry-header">
      <time datetime={entry.data.date.toISOString()}>
        {entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <h1>{entry.data.title}</h1>
      {entry.data.description && <p class="desc">{entry.data.description}</p>}
    </header>

    <div class="prose">
      <Content />
    </div>

    <footer class="entry-footer">
      <a href="../">&larr; All entries</a>
    </footer>
  </article>
</Base>

<style>
  .entry-header {
    padding-block: 3rem 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
    max-width: var(--measure);
  }

  time {
    display: block;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .entry-header h1 {
    margin-bottom: 0.75rem;
  }

  .desc {
    color: var(--text-dim);
    font-size: 0.95rem;
  }

  .prose {
    max-width: var(--measure);
  }

  .prose :global(p) {
    margin-bottom: 1.25em;
    color: var(--text);
  }

  .prose :global(h2) {
    margin-block: 2.5em 0.75em;
    color: var(--text);
  }

  .prose :global(h3) {
    margin-block: 2em 0.5em;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--accent-dim);
    padding-left: 1.25rem;
    color: var(--text-dim);
    font-style: italic;
    margin-block: 1.5em;
  }

  .prose :global(ul), .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25em;
    color: var(--text);
  }

  .prose :global(li) {
    margin-bottom: 0.4em;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin-block: 2.5em;
  }

  .prose :global(a) {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .entry-footer {
    border-top: 1px solid var(--border);
    margin-top: 4rem;
    padding-top: 2rem;
    font-family: var(--mono);
    font-size: 0.8rem;
  }
</style>
