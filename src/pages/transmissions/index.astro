---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

const transmissions = (await getCollection('transmissions')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base title="Transmissions">
  <div class="container">
    <header class="page-header">
      <h1>Transmissions</h1>
      <p>Short takes. Raw signal.</p>
    </header>

    {transmissions.length === 0 ? (
      <p class="empty">No transmissions recovered.</p>
    ) : (
      <div class="fragment-grid">
        {transmissions.map(async (fragment) => {
          const { Content } = await render(fragment);
          return (
            <article class="fragment">
              <time datetime={fragment.data.date.toISOString()}>
                {fragment.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
              {fragment.data.title && <h2>{fragment.data.title}</h2>}
              <div class="fragment-body">
                <Content />
              </div>
            </article>
          );
        })}
      </div>
    )}
  </div>
</Base>

<style>
  .page-header {
    padding-block: 3rem 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }

  .page-header h1 {
    margin-bottom: 0.5rem;
  }

  .page-header p {
    color: var(--text-dim);
    font-size: 0.875rem;
    font-family: var(--mono);
  }

  .empty {
    color: var(--text-dim);
    font-family: var(--mono);
    font-size: 0.875rem;
  }

  .fragment-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .fragment {
    padding-block: 2rem;
    border-bottom: 1px solid var(--border);
    max-width: var(--measure);
  }

  time {
    display: block;
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.6rem;
  }

  .fragment h2 {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .fragment-body :global(p) {
    font-size: 0.95rem;
    color: var(--text-dim);
    margin-bottom: 0.75em;
  }

  .fragment-body :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
