---
import Base from '../../layouts/Base.astro';
---

<Base title="Transmissions">
  <div class="container">
    <header class="page-header">
      <p class="recv">// SIGNAL LOG</p>
      <h1>Transmissions</h1>
      <p class="subtext">Signal log.</p>
    </header>
    <p class="empty">DATA PENDING — transmission incomplete.</p>
  </div>
</Base>

<style>
  .page-header {
    padding-block: 3rem 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }
  .recv {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    margin-bottom: 1rem;
  }
  .page-header h1 { margin-bottom: 0.4rem; }
  .subtext {
    font-size: 0.75rem;
    color: var(--text-dim);
    letter-spacing: 0.06em;
  }
  .empty {
    font-size: 0.75rem;
    color: var(--text-dim);
    letter-spacing: 0.08em;
  }
</style>
