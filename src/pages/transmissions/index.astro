---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
const base = import.meta.env.BASE_URL;

const transmissions = (await getCollection('transmissions'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Transmissions">
  <div class="container">
    <header class="page-header">
      <p class="recv">// SIGNAL LOG</p>
      <h1>Transmissions</h1>
      <p class="subtext">Official updates from Bungie.</p>
    </header>

    <ul class="entry-list">
      {transmissions.map(t => (
        <li>
          <a href={`${base}transmissions/${t.id}/`}>
            <span class="entry-date">{t.data.date.toISOString().slice(0,10).replace(/-/g,'.')}</span>
            <span class="entry-title">{t.data.title ?? t.id.toUpperCase()}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Base>

<style>
  .page-header {
    padding-block: 3rem 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }
  .recv {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    margin-bottom: 1rem;
  }
  .page-header h1 { margin-bottom: 0.4rem; }
  .subtext {
    font-size: 0.75rem;
    color: var(--text-dim);
    letter-spacing: 0.06em;
  }

  .entry-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--border);
  }
  .entry-list li { border-bottom: 1px solid var(--border); }
  .entry-list a {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 1.1rem 0;
    text-decoration: none;
    color: var(--text);
  }
  .entry-list a:hover .entry-title { color: var(--green); }
  .entry-date {
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    white-space: nowrap;
  }
  .entry-title {
    font-size: 0.85rem;
    letter-spacing: 0.06em;
  }
</style>
