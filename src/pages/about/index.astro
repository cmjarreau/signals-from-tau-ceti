---
import Base from '../../layouts/Base.astro';
---

<Base title="About">
  <div class="container">
    <header class="page-header">
      <h1>About</h1>
      <p class="subtext">What Marathon means to me.</p>
    </header>

    <div class="prose">
      <p>It's all about what Marathon means to me. That's what all of this boils down to.</p>
    </div>
  </div>
</Base>

<style>
  .page-header {
    padding-block: 3rem 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }

  .subtext {
    color: var(--text-dim);
    font-size: 0.875rem;
    font-family: var(--mono);
    margin-top: 0.5rem;
  }

  .prose {
    max-width: var(--measure);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .prose p {
    color: var(--text);
    font-size: 1rem;
    line-height: 1.75;
  }

  .prose em {
    color: var(--accent);
    font-style: normal;
  }
</style>
