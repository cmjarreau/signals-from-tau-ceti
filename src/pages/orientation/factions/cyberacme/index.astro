---
import Base from '../../../../layouts/Base.astro';
---

<Base title="CYBERACME">
  <div class="container">
    <header class="page-header">
      <p class="recv">// ORIENTATION · 02 · FACTIONS · 01</p>
      <h1>CYBERACME</h1>
      <p class="subtext">Operational systems and data infrastructure.</p>
    </header>

    <div class="faction-body">
      <div class="faction-image">
        <img src="/signals-from-tau-ceti/images/cyberacme.png" alt="CYBERACME" />
      </div>
      <div class="terminal" id="terminal">
        <p id="t0"><span class="prompt">C:\CYBERACME&gt;</span><span class="ttype"></span></p>
        <p id="t1" class="output hidden"><span class="ttype"></span></p>
        <p id="t2" class="output hidden"><span class="ttype"></span></p>
        <p id="t3" class="output hidden"><span class="ttype"></span></p>
        <p id="t4" class="output hidden"><span class="ttype"></span></p>
        <p id="t5" class="output hidden spacer"><span class="ttype"></span></p>
        <p id="t6" class="output hidden"><span class="ttype"></span></p>
        <p id="t7" class="output hidden spacer"><span class="ttype"></span></p>
        <p id="t8" class="output hidden"><span class="ttype"></span><span class="cursor"></span></p>
      </div>
    </div>

    <div class="back"><a href="../">← Factions</a></div>
  </div>
</Base>

<style>
  .page-header {
    padding-block: 3rem 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }
  .recv {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    margin-bottom: 1rem;
  }
  .page-header h1 { margin-bottom: 0.4rem; }
  .subtext {
    font-size: 0.75rem;
    color: var(--text-dim);
    letter-spacing: 0.06em;
  }

  .faction-body {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
    margin-bottom: 3rem;
  }
  .faction-image {
    flex-shrink: 0;
    border: 1px solid var(--border);
  }
  .faction-image img {
    display: block;
    width: 240px;
  }

  @media (max-width: 600px) {
    .faction-body {
      flex-direction: column;
    }
    .faction-image img {
      width: 100%;
    }
  }

  .terminal {
    flex: 1;
    background: #000;
    border: 1px solid var(--border);
    padding: 1.5rem;
    font-size: 0.75rem;
    line-height: 2;
    color: var(--green);
  }
  .terminal p { margin: 0; }
  .prompt { opacity: 0.5; }
  .output { padding-left: 0.5rem; }
  .spacer { margin-top: 0.75rem; }

  .hidden { visibility: hidden; }

  .back {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    border-top: 1px solid var(--border);
    padding-top: 2rem;
  }
  .back a { color: var(--text-dim); }
  .back a:hover { color: var(--green); }
</style>

<script>
  const lines = [
    ' CYBERACME.DAT',
    'FACTION: CYBERACME SYSTEMS, INC. [CyAc]',
    'ROLE: Interplanetary software and operational systems monopoly',
    'CLASSIFICATION: Megacorporation',
    'AGENT: ONI',
    'OVERVIEW: CYBERACME is the industry leader in operational systems development, data analysis, and cybersecurity. Their stated goal is to provide seamless integration of their advanced systems across all areas of modern life.',
    'Like modern Earth and Mars, the majority of the UESC MARATHON\'s systems were powered by CYAC. This deep-rooted connection to the origins and operation of both the MARATHON and NEW CASCADIA makes CYAC an eager participant in the [re]discovery of everything humanity lost in the TAU CETI system.',
    'The fact most modern RUNNER SHELLS include a version of one of CYAC\'s Onboard Navigational Intelligence [ONI] systems provides a unique advantage in CYAC\'s ability to create personal connections to the RUNNERS with boots-on-ground across TAU CETI IV\'s active ZONES.',
  ];

  const speed = 1; // ms per character
  const lineDelay = 100; // pause between lines

  function typeLine(el, text, done) {
    el.closest('p')?.classList.remove('hidden');
    let i = 0;
    const tick = setInterval(() => {
      el.textContent += text[i++];
      if (i >= text.length) { clearInterval(tick); done?.(); }
    }, speed);
  }

  function runSequence(index = 0) {
    if (index >= lines.length) return;
    const el = document.querySelector(`#t${index} .ttype`);
    if (!el) return;
    typeLine(el, lines[index], () => {
      setTimeout(() => runSequence(index + 1), lineDelay);
    });
  }

  document.addEventListener('DOMContentLoaded', () => runSequence());
</script>
