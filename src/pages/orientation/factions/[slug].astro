---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const factions = await getCollection('factions');
  return factions.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;

const bodyParagraphs = entry.body
  .split('\n\n')
  .map((p: string) => p.trim())
  .filter((p: string) => p.length > 0);

const terminalLines: string[] = [
  ` ${entry.id.toUpperCase()}.DAT`,
  `FACTION: ${data.name} [${data.designator}]`,
  `ROLE: ${data.role}`,
  `CLASSIFICATION: ${data.classification}`,
  `AGENT: ${data.agent}`,
  ...bodyParagraphs,
];
---

<Base title={data.name}>
  <div class="container">
    <header class="page-header">
      <p class="recv">// ORIENTATION · 02 · FACTIONS · {String(data.order ?? 1).padStart(2, '0')}</p>
      <h1>{entry.id.toUpperCase()}</h1>
      <p class="subtext">{data.subtext}</p>
    </header>

    <div class="faction-body">
      <div class="faction-image">
        <img src={`${base}images/${data.image}`} alt={entry.id.toUpperCase()} />
      </div>
      <div class="terminal" id="terminal">
        {terminalLines.map((_, i) => (
          i === 0 ? (
            <p id={`t${i}`}>
              <span class="prompt">C:\{entry.id.toUpperCase()}&gt;</span>
              <span class="ttype"></span>
            </p>
          ) : i === terminalLines.length - 1 ? (
            <p id={`t${i}`} class={`output hidden${i >= 5 ? ' spacer' : ''}`}>
              <span class="ttype"></span>
              <span class="cursor" id="end-cursor" style="visibility:hidden"></span>
            </p>
          ) : (
            <p id={`t${i}`} class={`output hidden${i >= 5 ? ' spacer' : ''}`}>
              <span class="ttype"></span>
            </p>
          )
        ))}
      </div>
    </div>

    <div class="back"><a href={`${base}orientation/factions/`}>← Factions</a></div>
  </div>
</Base>

<style>
  .page-header {
    padding-block: 3rem 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }
  .recv {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    margin-bottom: 1rem;
  }
  .page-header h1 { margin-bottom: 0.4rem; }
  .subtext {
    font-size: 0.75rem;
    color: var(--text-dim);
    letter-spacing: 0.06em;
  }

  .faction-body {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
    margin-bottom: 3rem;
  }
  .faction-image {
    flex-shrink: 0;
    border: 1px solid var(--border);
  }
  .faction-image img {
    display: block;
    width: 240px;
  }

  .terminal {
    flex: 1;
    background: #000;
    border: 1px solid var(--border);
    padding: 1.5rem;
    font-size: 0.75rem;
    line-height: 2;
    color: var(--green);
  }
  .terminal p { margin: 0; }
  .prompt { opacity: 0.5; }
  .output { padding-left: 0.5rem; }
  .spacer { margin-top: 0.75rem; }
  .hidden { visibility: hidden; }

  @media (max-width: 600px) {
    .faction-body { flex-direction: column; }
    .faction-image img { width: 100%; }
  }

  .back {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    border-top: 1px solid var(--border);
    padding-top: 2rem;
  }
  .back a { color: var(--text-dim); }
  .back a:hover { color: var(--green); }
</style>

<script define:vars={{ terminalLines }}>
  const speed = 1;
  const lineDelay = 100;

  function typeLine(el, text, done) {
    el.closest('p')?.classList.remove('hidden');
    let i = 0;
    const tick = setInterval(() => {
      el.textContent += text[i++];
      if (i >= text.length) { clearInterval(tick); done?.(); }
    }, speed);
  }

  function runSequence(index = 0) {
    if (index >= terminalLines.length) {
      const cursor = document.getElementById('end-cursor');
      const lastType = document.querySelector(`#t${terminalLines.length - 1} .ttype`);
      lastType.appendChild(cursor);
      cursor.style.visibility = 'visible';
      return;
    }
    const el = document.querySelector(`#t${index} .ttype`);
    if (!el) return;
    typeLine(el, terminalLines[index], () => {
      setTimeout(() => runSequence(index + 1), lineDelay);
    });
  }

  document.addEventListener('DOMContentLoaded', () => runSequence());
</script>
