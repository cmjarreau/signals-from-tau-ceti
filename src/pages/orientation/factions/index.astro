---
import Base from '../../../layouts/Base.astro';
---

<Base title="FACTIONS">
  <div class="container">
    <header class="page-header">
      <p class="recv">// ORIENTATION · 02 · FACTIONS</p>
      <h1>FACTIONS</h1>
      <p class="subtext">The corporations want their assets back, and you are the retrieval mechanism.</p>
    </header>

    <ul class="faction-list">
      <li>
        <a href="cyberacme/">
          <span class="faction-id">01</span>
          <span class="faction-name">CYBERACME</span>
        </a>
      </li>
    </ul>

    <div class="back"><a href="../">← Orientation</a></div>
  </div>
</Base>

<style>
  .page-header {
    padding-block: 3rem 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }
  .recv {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    margin-bottom: 1rem;
  }
  .page-header h1 { margin-bottom: 0.4rem; }
  .subtext {
    font-size: 0.75rem;
    color: var(--text-dim);
    letter-spacing: 0.06em;
  }

  .faction-list {
    list-style: none;
    padding: 0;
    margin: 0 0 4rem;
    border-top: 1px solid var(--border);
  }
  .faction-list li {
    border-bottom: 1px solid var(--border);
  }
  .faction-list a {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.1rem 0;
    text-decoration: none;
    color: var(--text);
  }
  .faction-list a:hover .faction-name { color: var(--green); }
  .faction-list a:hover .faction-arrow { color: var(--green); }
  .faction-id {
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    color: var(--text-dim);
    min-width: 1.5rem;
  }
  .faction-name {
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    flex: 1;
  }
  .faction-arrow {
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  .back {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    border-top: 1px solid var(--border);
    padding-top: 2rem;
  }
  .back a { color: var(--text-dim); }
  .back a:hover { color: var(--green); }
</style>
