---
import Base from '../../../layouts/Base.astro';
---

<Base title="FACTIONS">
  <div class="container">
    <header class="page-header">
      <p class="recv">// ORIENTATION · 02 · FACTIONS</p>
      <h1>FACTIONS</h1>
      <p class="subtext">The corporations want their assets back, and you are the retrieval mechanism.</p>
    </header>
    <p class="empty">DATA PENDING — transmission incomplete.</p>
    <div class="back"><a href="../">← Orientation</a></div>
  </div>
</Base>

<style>
  .page-header {
    padding-block: 3rem 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }
  .recv {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    margin-bottom: 1rem;
  }
  .page-header h1 { margin-bottom: 0.4rem; }
  .subtext {
    font-size: 0.75rem;
    color: var(--text-dim);
    letter-spacing: 0.06em;
  }
  .empty {
    font-size: 0.75rem;
    color: var(--text-dim);
    letter-spacing: 0.08em;
    margin-bottom: 3rem;
  }
  .back {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    border-top: 1px solid var(--border);
    padding-top: 2rem;
  }
  .back a { color: var(--text-dim); }
  .back a:hover { color: var(--green); }
</style>
