---
import Base from '../../layouts/Base.astro';
---

<Base title="Orientation">
  <div class="container">
    <header class="page-header">
      <h1>Orientation</h1>
      <p class="subtext">How to play Marathon. What to know before you start.</p>
    </header>

    <p class="empty">Briefing incoming.</p>
  </div>
</Base>

<style>
  .page-header {
    padding-block: 3rem 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }

  .page-header h1 {
    margin-bottom: 0.5rem;
  }

  .subtext {
    color: var(--text-dim);
    font-size: 0.875rem;
    font-family: var(--mono);
  }

  .empty {
    color: var(--text-dim);
    font-family: var(--mono);
    font-size: 0.875rem;
  }
</style>
