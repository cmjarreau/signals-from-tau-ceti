---
import Base from '../layouts/Base.astro';
---

<Base>
  <div class="container">
    <section class="hero">
      <h1 class="cursor">Signals from Tau Ceti</h1>
      <p class="tagline">ANOMALOUS SIGNAL DETECTED</p>
      <p class="tagline-sub">Origin: Tau Ceti IV</p>
      <p class="tagline-sub">Source: unverified</p>
    </section>

    <section class="index-grid">
      <a href="orientation/" class="card">
        <h2>Orientation</h2>
        <p>How to play Marathon. What to know before you start.</p>
      </a>
      <a href="entries/" class="card">
        <h2>Entries</h2>
        <p>Long-form writing — analysis, lore essays, and personal record.</p>
      </a>
      <a href="transmissions/" class="card">
        <h2>Transmissions</h2>
        <p>Short takes. Lore scraps, stray observations, raw signal.</p>
      </a>
      <a href="about/" class="card">
        <h2>About</h2>
        <p>What Marathon means to me.</p>
      </a>
    </section>
  </div>
</Base>

<style>
  .hero {
    padding-block: 5rem 4rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 4rem;
  }


  h1 {
    margin-bottom: 1.5rem;
  }

  .tagline {
    color: var(--text-bright);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    margin-bottom: 0.4rem;
  }

  .tagline-sub {
    font-size: 0.8rem;
    color: var(--text-dim);
    letter-spacing: 0.08em;
    margin-bottom: 0.2rem;
  }

  .index-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1px;
    border: 1px solid var(--border);
    background: var(--border);
  }

  .card {
    display: block;
    padding: 2rem;
    background: var(--surface);
    color: var(--text);
    transition: background var(--transition);
  }

  .card:hover {
    background: var(--surface-2);
  }

  .card h2 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--green);
    margin-bottom: 0.75rem;
    text-shadow: 0 0 8px rgba(0, 255, 65, 0.3);
  }

  .card p {
    font-size: 0.8rem;
    color: var(--text);
    line-height: 1.6;
  }
</style>
